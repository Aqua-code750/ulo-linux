#!/bin/bash
# Hook to set the password for the 'ulo' live user created by casper

# Create a systemd oneshot service that runs on boot to set the password
cat << 'EOF' > /etc/systemd/system/set-ulo-password.service
[Unit]
Description=Set Ulo Live User Password
After=multi-user.target

[Service]
Type=oneshot
ExecStart=/bin/bash -c "echo 'ulo:67' | chpasswd"

[Install]
WantedBy=multi-user.target
EOF

# Enable the service so it runs at every live boot
systemctl enable set-ulo-password.service
