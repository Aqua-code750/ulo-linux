# a) Purpose: Linux Kernel Configuration tuned for Ulo Linux (Agentic OS)
# c) Install/Test: Copied to .config during the PKGBUILD process.
# d) Open decisions: Enabling CONFIG_PREEMPT_VOLUNTARY for a balance between background AI throughput and UI responsiveness.

# --- ULO AGENTIC OS KERNEL TUNING ---

# 1. CPU Scheduling (The "Bytebot / Agent" mix)
# Instead of hard real-time gaming schedulers, we want maximum throughput for background 
# LLM/AI tasks without freezing the custom front-end UI.
CONFIG_PREEMPT_VOLUNTARY=y
CONFIG_NO_HZ_FULL=y

# 2. Asynchronous I/O (Crucial for agent file searching and DB ops)
CONFIG_IO_URING=y
CONFIG_AIO=y

# 3. Virtualization (QEMU-First Citizen)
# We bake these directly into the kernel (=y) instead of modules (=m) 
# so the OS boots instantly inside a VM.
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_HW_RANDOM_VIRTIO=y
CONFIG_DRM_VIRTIO_GPU=y

# 4. Filesystems (Arch/Ubuntu blend)
# We use BTRFS as default for snapshot rollbacks (Ubuntu's ZFS/BTRFS reliability)
CONFIG_BTRFS_FS=y
CONFIG_BTRFS_FS_POSIX_ACL=y
CONFIG_OVERLAY_FS=y # Required for Flatpak/Container sandboxing

# 5. Security (Ubuntu's influence)
# AppArmor is enabled by default to sandbox the agent's actions securely.
CONFIG_SECURITY_APPARMOR=y
CONFIG_SECURITY_APPARMOR_BOOTPARAM_VALUE=1
CONFIG_DEFAULT_SECURITY_APPARMOR=y

# 6. Networking
# BBR TCP congestion control allows the AI agent to pull APIs/models over the network rapidly.
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_BBR=y

# 7. Debloat
# Disable ancient hardware we don't need for a modern QEMU/Agentic OS.
# CONFIG_FLOPPY is not set
# CONFIG_IDE is not set
# CONFIG_WLAN_VENDOR_ATMEL is not set (and thousands of others omitted for brevity)
